## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
bin/
obj/

# ASP.NET temporary files
*.dll
*.pdb

# IIS Express
.vs/
.vscode/

# NuGet Packages
packages/
*.nupkg

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# SQL Server files
*.mdf
*.ldf

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Publish folder
publish/